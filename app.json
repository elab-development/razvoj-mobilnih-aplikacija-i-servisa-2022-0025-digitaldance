{
  "expo": {
    "name": "DigitalDance",
    "slug": "DigitalDance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "digitaldance",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "DigitalDance koristi kameru da bi snimila video svog plesa.",
        "NSPhotoLibraryUsageDescription": "DigitalDance pristupa galeriji da bi otpremila video ili profilnu fotografiju.",
        "NSLocationWhenInUseUsageDescription": "DigitalDance koristi lokaciju da bi prikazala audicije u tvojoj blizini."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8ECFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#F8ECFF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DigitalDance pristupa galeriji da bi otpremila video ili profilnu fotografiju.",
          "cameraPermission": "DigitalDance koristi kameru da bi snimila video svog plesa."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DigitalDance koristi lokaciju da bi prikazala audicije u tvojoj blizini."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
